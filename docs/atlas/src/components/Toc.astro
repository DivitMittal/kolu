---
// Table of contents — built from the note's headings (Astro auto-assigns each
// heading an `id`, so the anchors resolve). Fed by the page route, which gets
// `headings` from `render(note)`. Renders nothing for a note with <2 headings.
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
  minDepth?: number;
  maxDepth?: number;
}
const { headings, minDepth = 2, maxDepth = 3 } = Astro.props as Props;
const items = headings.filter((h) => h.depth >= minDepth && h.depth <= maxDepth);
---
{
  items.length > 1 && (
    <nav class="toc" aria-label="Table of contents">
      <p class="toc-title">Contents</p>
      <ul class="toc-list">
        {items.map((h) => (
          <li class={`toc-item toc-d${h.depth}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
<style>
  .toc {
    margin: 1.8rem 0;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--surface);
  }
  .toc-title {
    margin: 0 0 0.5rem;
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .toc-list { list-style: none; margin: 0; padding: 0; columns: 2; column-gap: 2rem; }
  .toc-item { margin: 0.18rem 0; break-inside: avoid; }
  .toc-item a { color: var(--ink-dim); text-decoration: none; font-size: 0.9rem; }
  .toc-item a:hover { color: var(--amber); }
  .toc-d3 { padding-left: 1rem; }
  .toc-d3 a { font-size: 0.82rem; color: var(--ink-muted); }
  @media (max-width: 34rem) {
    .toc-list { columns: 1; }
  }
</style>
