---
// A note-local, co-located component (namespaced to the second-brain note).
// Demonstrates tier 2: a real .astro file — scoped <style>, typed props, plain
// HTML attributes (no JSX gotcha) — imported just for one note, not the kit.
interface Props {
  label: string;
}
const { label } = Astro.props;
---
<span class="stamp">{label}</span>
<style>
  .stamp {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    border: 1px dashed var(--rule);
    border-radius: 5px;
    padding: 0.15em 0.5em;
  }
</style>
